DISCORD_TOKEN=put-your-discord-bot-token-here
# Optional global PrettyWords config admins. Comma or space separated Discord user IDs.
BOT_ADMIN_IDS=

# AI_PROVIDER: ollama, openai, auto, or none.
# Oracle A1 Flex recommendation: ollama + small ARM-friendly model.
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_TIMEOUT_SECONDS=30
# false = A1-friendly: only locally suspicious messages go to AI.
AI_SCAN_ALL=false

# Optional paid fallback. Use AI_PROVIDER=openai to force this.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# Optional. Set for instant slash-command sync in one test server.
DISCORD_TEST_GUILD_ID=

# Optional.
DATABASE_PATH=data/prettywords.sqlite3
LOG_LEVEL=INFO
ENABLE_MEMBERS_INTENT=false
