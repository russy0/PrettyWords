DISCORD_TOKEN=put-your-discord-bot-token-here
# (선택) PrettyWords 전역 설정 관리자. Discord 사용자 ID를 콤마 또는 공백으로 구분.
BOT_ADMIN_IDS=

# AI_PROVIDER: ollama, openai, groq, auto, none 중 선택.
# Oracle A1 Flex 권장 조합: groq(무료 호스팅 API)를 기본으로 쓰고,
# Groq가 rate limit에 걸렸을 때만 로컬 ollama로 잠시 전환합니다.
AI_PROVIDER=groq
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_TIMEOUT_SECONDS=30
# false = A1 Flex 친화적 설정: 로컬 필터에서 의심스럽다고 판단된 메시지만 AI로 보냅니다.
AI_SCAN_ALL=false

# (선택) 유료 폴백. AI_PROVIDER=openai로 강제 지정 시 사용됩니다.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# Groq (https://console.groq.com) 무료 호스팅 추론 API. 봇 호스트(예: Oracle A1 Flex)가
# Ollama를 돌리기에 너무 약할 때 권장하는 방식입니다.
# AI_PROVIDER=groq일 때, AI 판정이 필요한 메시지는 큐에 쌓였다가
# (GROQ_BATCH_SIZE개가 모이거나 GROQ_BATCH_WINDOW_SECONDS초가 지나는 것 중
# 먼저 도달하는 조건에 맞춰) 배치로 묶여 Groq에 전송됩니다. 무료 등급의
# 요청 횟수 제한을 최대한 아끼기 위함입니다.
#
# Groq 무료 API 키를 여러 개(예: 서로 다른 Groq 계정/프로젝트) 등록할 수 있습니다.
# 콤마, 세미콜론, 공백 중 아무거나로 구분하면 됩니다:
#   GROQ_API_KEY=gsk_첫번째_키, gsk_두번째_키, gsk_세번째_키
# PrettyWords는 키들 사이를 자동으로 순환합니다: 한 키가 rate limit(HTTP 429)에
# 걸리면 그 키만 짧은 개별 쿨다운에 들어가고, 곧바로 다음 키로 재시도하므로
# 키 하나가 막혔다고 검열이 멈추지 않습니다.
# 등록된 키 전부가 동시에 rate limit에 걸렸을 때만, PrettyWords는
# GROQ_RATE_LIMIT_COOLDOWN_SECONDS 동안 로컬 Ollama 모델(위 OLLAMA_*)로
# 전환했다가 이후 다시 Groq로 재시도합니다.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BATCH_SIZE=30
GROQ_BATCH_WINDOW_SECONDS=8
GROQ_RATE_LIMIT_COOLDOWN_SECONDS=60

# (선택) 테스트 서버 한 곳에 슬래시 명령을 즉시 동기화하고 싶을 때 설정.
DISCORD_TEST_GUILD_ID=

# (선택)
DATABASE_PATH=data/prettywords.sqlite3
LOG_LEVEL=INFO
ENABLE_MEMBERS_INTENT=false
